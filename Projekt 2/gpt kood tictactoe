import tkinter as tk
from tkinter import messagebox

root = tk.Tk()
root.title("Tic Tac Toe")
root.geometry("500x600")
root.resizable(False, False)

current_player = "X"
board = [""] * 9
game_over = False
buttons = []


def check_winner():
    winning_combinations = [
        [0, 1, 2],
        [3, 4, 5],
        [6, 7, 8],
        [0, 3, 6],
        [1, 4, 7],
        [2, 5, 8],
        [0, 4, 8],
        [2, 4, 6]
    ]

    for combo in winning_combinations:
        a, b, c = combo
        if board[a] == board[b] == board[c] != "":
            return board[a]
    return None


def check_draw():
    return "" not in board


def button_click(index):
    global current_player, game_over

    if board[index] != "" or game_over:
        return

    board[index] = current_player
    buttons[index].config(text=current_player)

    winner = check_winner()
    if winner:
        status_label.config(text=f"{winner} wins!")
        messagebox.showinfo("Game Over", f"Player {winner} wins!")
        game_over = True
        return

    if check_draw():
        status_label.config(text="It's a draw!")
        messagebox.showinfo("Game Over", "It's a draw!")
        game_over = True
        return

    current_player = "O" if current_player == "X" else "X"
    status_label.config(text=f"{current_player}'s turn")


def reset_game():
    global current_player, board, game_over

    current_player = "X"
    board = [""] * 9
    game_over = False
    status_label.config(text=f"{current_player}'s turn")

    for button in buttons:
        button.config(text="")


title_label = tk.Label(root, text="Tic Tac Toe", font=("Arial", 24, "bold"))
title_label.pack(pady=20)

status_label = tk.Label(root, text="X's turn", font=("Arial", 18))
status_label.pack(pady=10)

board_frame = tk.Frame(root)
board_frame.pack(pady=20)

for row in range(3):
    for col in range(3):
        index = row * 3 + col
        button = tk.Button(
            board_frame,
            text="",
            font=("Arial", 32, "bold"),
            width=5,
            height=2,
            command=lambda i=index: button_click(i)
        )
        button.grid(row=row, column=col, padx=5, pady=5)
        buttons.append(button)

reset_button = tk.Button(root, text="Restart Game", font=("Arial", 16), command=reset_game)
reset_button.pack(pady=20)

root.mainloop()